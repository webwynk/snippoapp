NODE_ENV=production
PORT=4000

# Generate with: npm run jwt:secret
JWT_SECRET=replace-with-96-char-random-secret
JWT_EXPIRES_IN=7d

# Frontend domains allowed to call API
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Hostinger runs Node behind a proxy
TRUST_PROXY=true

# API throttling
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Keep this file outside deploy temp folders if needed
DATA_FILE=./data/db.json

# Avoid demo credentials in production
SEED_MODE=secure
ADMIN_BOOTSTRAP_NAME=Owner Admin
ADMIN_BOOTSTRAP_EMAIL=owner@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-password
